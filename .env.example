# Application Configuration
APP_NAME=STARTER-KIT
APP_ENV=development
PORT=8080
GIN_MODE=release

# Database Configuration
# For Docker Compose, set DB_HOST to service name (e.g. postgres)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASS=your_password
DB_NAME=starter_kit
DB_SSLMODE=disable

# JWT Configuration
JWT_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_EXP=24
REFRESH_TOKEN_EXP_HOURS=168

# Google Authentication
GOOGLE_CLIENT_ID=
# Optional comma-separated allowed audiences, for example web and mobile client IDs
GOOGLE_CLIENT_IDS=

# Email Sender Configuration
# Used by optional register OTP and password reset email flows.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=
SMTP_FROM=
SMTP_SUBJECT=Your Registration OTP
RESET_SUBJECT=Reset Your Password
AUTH_EMAIL_APP_NAME=STARTER-KIT
CONFIG_PUBLIC_REGISTRATION=auth.public_registration_enabled
CONFIG_REGISTER_OTP=auth.register_otp_enabled
CONFIG_PASSWORD_RESET_EMAIL=auth.password_reset_email_enabled

# Register OTP Configuration
OTP_SECRET=change-this-otp-secret
OTP_TTL=5m
OTP_TTL_SECONDS=300
OTP_COOLDOWN=60s
OTP_COOLDOWN_SECONDS=60
OTP_RATE_LIMIT=5
OTP_RATE_WINDOW=5m
OTP_RATE_WINDOW_SECONDS=300
OTP_MAX_ATTEMPTS=5

# Password Reset Email Configuration
RESET_SECRET=change-this-reset-secret
RESET_TTL=15m
RESET_TTL_SECONDS=900
RESET_COOLDOWN=60s
RESET_COOLDOWN_SECONDS=60
RESET_RATE_LIMIT=5
RESET_RATE_WINDOW=15m
RESET_RATE_WINDOW_SECONDS=900
RESET_URL_TEMPLATE=http://localhost:5173/reset-password?token={token}

# Database Migration Configuration
PATH_MIGRATE=file://migrations

# Cache Configuration (in seconds)
TTL_CACHE_CONFIG_APP=86400
# Location cache TTL. Supports duration strings like 4320h or numeric seconds.
LOCATION_CACHE_TTL=4320h
LOCATION_SOURCE_YEAR=2025
LOCATION_SERVICE_BASE_URL=https://location-service.com
LOCATION_SERVICE_TIMEOUT_SECONDS=20

# Application Config ID (Optional)
CONFIG_ID=

# Redis Configuration (for session management and rate limiting)
# For Docker Compose, set REDIS_HOST to service name (e.g. redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Rate Limiting Configuration
LOGIN_ATTEMPT_LIMIT=5
LOGIN_ATTEMPT_WINDOW_SECONDS=60
LOGIN_BLOCK_DURATION_SECONDS=300
REGISTER_RATE_LIMIT=5
REGISTER_RATE_WINDOW_SECONDS=60
PERMISSION_CACHE_TTL=5m
PERMISSION_CACHE_TTL_SECONDS=300

# Storage Configuration (for file/image uploads)
# Supported providers: "minio" or "r2" (Cloudflare R2)
STORAGE_PROVIDER=minio
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET_NAME=uploads
STORAGE_USE_SSL=false
STORAGE_BASE_URL=http://localhost:9000
STORAGE_REGION=auto

# Cloudflare R2 Configuration (only if STORAGE_PROVIDER=r2)
R2_ACCOUNT_ID=your_cloudflare_account_id

# Logging
LOG_LEVEL=5
LOG_FORMAT=json
NODE=api

# Runtime
# Set true/1 to run migration at container startup via entrypoint
RUN_MIGRATION=true
